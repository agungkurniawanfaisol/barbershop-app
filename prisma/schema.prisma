// BarberPro POS — Database Schema
// PostgreSQL via Supabase | UUID primary keys | Soft delete on all tables

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
  BARBER
}

enum PaymentMethod {
  CASH
  QRIS
  DEBIT
  TRANSFER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum ExpenseCategory {
  RENT
  UTILITIES
  SUPPLIES
  SALARY
  MARKETING
  MAINTENANCE
  OTHER
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
}

// ─── Auth & RBAC ─────────────────────────────────────────────────────────────

model User {
  id        String    @id @default(uuid()) @db.Uuid
  email     String    @unique
  fullName  String    @map("full_name")
  role      UserRole  @default(CASHIER)
  isActive  Boolean   @default(true) @map("is_active")
  avatarUrl String?   @map("avatar_url")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  employee         Employee?
  transactions     Transaction[] @relation("CashierTransactions")
  expenses         Expense[]
  auditLogs        AuditLog[]
  rolePermissions  RolePermission[]

  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

model Permission {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique
  name        String
  description String?
  module      String
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  rolePermissions RolePermission[]

  @@index([module])
  @@index([deletedAt])
  @@map("permissions")
}

model RolePermission {
  id           String    @id @default(uuid()) @db.Uuid
  role         UserRole
  permissionId String    @map("permission_id") @db.Uuid
  userId       String?   @map("user_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  permission Permission @relation(fields: [permissionId], references: [id])
  user       User?      @relation(fields: [userId], references: [id])

  @@unique([role, permissionId])
  @@index([deletedAt])
  @@map("role_permissions")
}

// ─── Employees ───────────────────────────────────────────────────────────────

model Employee {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String?   @unique @map("user_id") @db.Uuid
  name            String
  phone           String?
  email           String?
  address         String?
  photoUrl        String?   @map("photo_url")
  role            UserRole  @default(BARBER)
  commissionRate  Decimal   @default(0) @map("commission_rate") @db.Decimal(5, 2)
  salary          Decimal   @default(0) @db.Decimal(12, 2)
  isActive        Boolean   @default(true) @map("is_active")
  hireDate        DateTime? @map("hire_date")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  user              User?         @relation(fields: [userId], references: [id])
  transactions      Transaction[] @relation("BarberTransactions")
  favoriteCustomers Customer[]    @relation("FavoriteBarber")
  reservations      Reservation[]
  attendances       Attendance[]

  @@index([role])
  @@index([isActive])
  @@index([deletedAt])
  @@map("employees")
}

model Attendance {
  id         String           @id @default(uuid()) @db.Uuid
  employeeId String           @map("employee_id") @db.Uuid
  date       DateTime         @db.Date
  clockIn    DateTime?        @map("clock_in")
  clockOut   DateTime?        @map("clock_out")
  status     AttendanceStatus @default(PRESENT)
  notes      String?
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  deletedAt  DateTime?        @map("deleted_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@index([date])
  @@index([deletedAt])
  @@map("attendances")
}

// ─── Customers ───────────────────────────────────────────────────────────────

model Customer {
  id               String    @id @default(uuid()) @db.Uuid
  name             String
  phone            String    @unique
  gender           Gender?
  birthday         DateTime? @db.Date
  visitCount       Int       @default(0) @map("visit_count")
  lastVisit        DateTime? @map("last_visit")
  favoriteBarberId String?   @map("favorite_barber_id") @db.Uuid
  notes            String?
  loyaltyPoints    Int       @default(0) @map("loyalty_points")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  favoriteBarber Employee?     @relation("FavoriteBarber", fields: [favoriteBarberId], references: [id])
  transactions   Transaction[]
  reservations   Reservation[]

  @@index([name])
  @@index([lastVisit])
  @@index([deletedAt])
  @@map("customers")
}

// ─── Services ────────────────────────────────────────────────────────────────

model ServiceCategory {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  description String?
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  services Service[]

  @@index([sortOrder])
  @@index([deletedAt])
  @@map("service_categories")
}

model Service {
  id              String    @id @default(uuid()) @db.Uuid
  categoryId      String?   @map("category_id") @db.Uuid
  name            String
  description     String?
  price           Decimal   @db.Decimal(12, 2)
  durationMinutes Int       @default(30) @map("duration_minutes")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  category         ServiceCategory?  @relation(fields: [categoryId], references: [id])
  transactionItems TransactionItem[]
  reservations     Reservation[]

  @@index([name])
  @@index([isActive])
  @@index([deletedAt])
  @@map("services")
}

// ─── Transactions (POS) ──────────────────────────────────────────────────────

model Transaction {
  id                String            @id @default(uuid()) @db.Uuid
  transactionNumber String            @unique @map("transaction_number")
  customerId        String?           @map("customer_id") @db.Uuid
  barberId          String?           @map("barber_id") @db.Uuid
  cashierId         String            @map("cashier_id") @db.Uuid
  subtotal          Decimal           @db.Decimal(12, 2)
  discountAmount    Decimal           @default(0) @map("discount_amount") @db.Decimal(12, 2)
  discountPercent   Decimal           @default(0) @map("discount_percent") @db.Decimal(5, 2)
  taxAmount         Decimal           @default(0) @map("tax_amount") @db.Decimal(12, 2)
  taxPercent        Decimal           @default(0) @map("tax_percent") @db.Decimal(5, 2)
  total             Decimal           @db.Decimal(12, 2)
  barberCommissionRate   Decimal?       @map("barber_commission_rate") @db.Decimal(5, 2)
  barberCommissionAmount Decimal?       @map("barber_commission_amount") @db.Decimal(12, 2)
  paymentMethod     PaymentMethod     @map("payment_method")
  status            TransactionStatus @default(COMPLETED)
  notes             String?
  paidAt            DateTime          @default(now()) @map("paid_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  deletedAt         DateTime?         @map("deleted_at")

  customer Customer?         @relation(fields: [customerId], references: [id])
  barber   Employee?         @relation("BarberTransactions", fields: [barberId], references: [id])
  cashier  User              @relation("CashierTransactions", fields: [cashierId], references: [id])
  items    TransactionItem[]

  @@index([paidAt])
  @@index([status])
  @@index([status, paidAt])
  @@index([customerId])
  @@index([barberId])
  @@index([barberId, status, paidAt])
  @@index([deletedAt])
  @@map("transactions")
}

model TransactionItem {
  id            String    @id @default(uuid()) @db.Uuid
  transactionId String    @map("transaction_id") @db.Uuid
  serviceId     String?   @map("service_id") @db.Uuid
  serviceName   String    @map("service_name")
  price         Decimal   @db.Decimal(12, 2)
  quantity      Int       @default(1)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  service     Service?    @relation(fields: [serviceId], references: [id])

  @@index([transactionId])
  @@index([deletedAt])
  @@map("transaction_items")
}

// ─── Expenses ────────────────────────────────────────────────────────────────

model Expense {
  id          String          @id @default(uuid()) @db.Uuid
  title       String
  description String?
  amount      Decimal         @db.Decimal(12, 2)
  category    ExpenseCategory @default(OTHER)
  expenseDate DateTime        @map("expense_date") @db.Date
  recordedById String         @map("recorded_by_id") @db.Uuid
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  deletedAt   DateTime?       @map("deleted_at")

  recordedBy User @relation(fields: [recordedById], references: [id])

  @@index([expenseDate])
  @@index([category])
  @@index([deletedAt])
  @@map("expenses")
}

// ─── Reservations ────────────────────────────────────────────────────────────

model Reservation {
  id          String            @id @default(uuid()) @db.Uuid
  customerId  String            @map("customer_id") @db.Uuid
  barberId    String?           @map("barber_id") @db.Uuid
  serviceId   String?           @map("service_id") @db.Uuid
  scheduledAt DateTime          @map("scheduled_at")
  status      ReservationStatus @default(PENDING)
  notes       String?
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  deletedAt   DateTime?         @map("deleted_at")

  customer Customer  @relation(fields: [customerId], references: [id])
  barber   Employee? @relation(fields: [barberId], references: [id])
  service  Service?  @relation(fields: [serviceId], references: [id])

  @@index([scheduledAt])
  @@index([status])
  @@index([deletedAt])
  @@map("reservations")
}

// ─── Settings & Audit ────────────────────────────────────────────────────────

model Setting {
  id        String    @id @default(uuid()) @db.Uuid
  key       String    @unique
  value     Json
  category  String    @default("general")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([category])
  @@index([deletedAt])
  @@map("settings")
}

model AuditLog {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  action    String
  entity    String
  entityId  String?   @map("entity_id")
  oldValue  Json?     @map("old_value")
  newValue  Json?     @map("new_value")
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("audit_logs")
}
